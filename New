import 'package:flutter/material.dart';

void main() {
  runApp(const GumshoeEmpire());
}

class GumshoeEmpire extends StatelessWidget {
  const GumshoeEmpire({super.key});

  @override
  Widget build(BuildContext context) {
    return MaterialApp(
      title: 'Gumshoe Empire',
      debugShowCheckedModeBanner: false,
      theme: ThemeData(
        brightness: Brightness.dark,
        fontFamily: 'Arial',
      ),
      home: const SplashScreen(),
    );
  }
}

class SplashScreen extends StatefulWidget {
  const SplashScreen({super.key});

  @override
  State<SplashScreen> createState() => _SplashScreenState();
}

class _SplashScreenState extends State<SplashScreen> {

  @override
  void initState() {
    super.initState();

    Future.delayed(const Duration(seconds: 3), () {
      Navigator.pushReplacement(
        context,
        MaterialPageRoute(
          builder: (_) => const LoginScreen(),
        ),
      );
    });
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      backgroundColor: Colors.black,
      body: Center(
        child: Column(
          mainAxisAlignment: MainAxisAlignment.center,
          children: [

            const Icon(
              Icons.search,
              color: Colors.white,
              size: 80,
            ),

            const SizedBox(height: 20),

            const Text(
              "GUMSHOE EMPIRE",
              style: TextStyle(
                fontSize: 32,
                fontWeight: FontWeight.bold,
                letterSpacing: 2,
              ),
            ),

            const SizedBox(height: 30),

            const SizedBox(
              width: 220,
              child: LinearProgressIndicator(
                minHeight: 6,
              ),
            ),

            const SizedBox(height: 15),

            Text(
              "Loading...",
              style: TextStyle(
                color: Colors.grey.shade400,
              ),
            )

          ],
        ),
      ),
    );
  }
}

class LoginScreen extends StatelessWidget {
  const LoginScreen({super.key});

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      backgroundColor: const Color(0xff111111),
      body: Center(
        child: SizedBox(
          width: 320,
          child: Column(
            mainAxisAlignment: MainAxisAlignment.center,
            children: [

              const Icon(
                Icons.search,
                size: 70,
              ),

              const SizedBox(height: 20),

              const Text(
                "Welcome Detective",
                style: TextStyle(
                  fontSize: 28,
                  fontWeight: FontWeight.bold,
                ),
              ),

              const SizedBox(height: 45),

              SizedBox(
                width: double.infinity,
                height: 55,
                child: ElevatedButton(
                  onPressed: () {
                    Navigator.push(
                      context,
                      MaterialPageRoute(
                        builder: (_) => const CreateDetectiveScreen(),
                      ),
                    );
                  },
                  child: const Text("Play as Guest"),
                ),
              ),

              const SizedBox(height: 18),

              SizedBox(
                width: double.infinity,
                height: 55,
                child: OutlinedButton(
                  onPressed: () {},
                  child: const Text("Sign in with Google"),
                ),
              ),

            ],
          ),
        ),
      ),
    );
  }
}

class CreateDetectiveScreen extends StatelessWidget {
  const CreateDetectiveScreen({super.key});

  @override
  Widget build(BuildContext context) {
    final TextEditingController controller = TextEditingController();

    return Scaffold(
      appBar: AppBar(
        title: const Text("Create Detective"),
      ),
      body: Padding(
        padding: const EdgeInsets.all(24),
        child: Column(

          children: [

            TextField(
              controller: controller,
              decoration: const InputDecoration(
                labelText: "Detective Name",
              ),
            ),

            const SizedBox(height: 30),

            SizedBox(
              width: double.infinity,
              height: 55,
              child: ElevatedButton(
                onPressed: () {

                  Navigator.pushReplacement(
                    context,
                    MaterialPageRoute(
                      builder: (_) => HomeScreen(
                        detectiveName: controller.text.isEmpty
                            ? "Detective"
                            : controller.text,
                      ),
                    ),
                  );

                },
                child: const Text("Begin Investigation"),
              ),
            )

          ],
        ),
      ),
    );
  }
}

class HomeScreen extends StatelessWidget {

  final String detectiveName;

  const HomeScreen({
    super.key,
    required this.detectiveName,
  });

  @override
  Widget build(BuildContext context) {

    return Scaffold(
      backgroundColor: const Color(0xff0d0d0d),

      appBar: AppBar(
        title: const Text("Gumshoe Empire"),
      ),

      body: Center(
        child: Text(
          "Welcome, $detectiveName",
          style: const TextStyle(
            fontSize: 30,
            fontWeight: FontWeight.bold,
          ),
        ),
      ),
    );

  }
}
