// ==========================================
// SCREEN 1: Napo Studio Intro (Fixed Stretching)
// ==========================================
class NapoStudioIntroScreen extends StatefulWidget {
  const NapoStudioIntroScreen({super.key});

  @override
  State<NapoStudioIntroScreen> createState() => _NapoStudioIntroScreenState();
}

class _NapoStudioIntroScreenState extends State<NapoStudioIntroScreen> with SingleTickerProviderStateMixin {
  late AnimationController _fadeController;
  late Animation<double> _fadeAnimation;

  @override
  void initState() {
    super.initState();
    
    _fadeController = AnimationController(
      vsync: this,
      duration: const Duration(milliseconds: 1000),
    );
    _fadeAnimation = Tween<double>(begin: 0.0, end: 1.0).animate(_fadeController);

    _fadeController.forward();

    Timer(const Duration(seconds: 3), () async {
      await _fadeController.reverse();
      if (mounted) {
        Navigator.pushReplacement(
          context,
          MaterialPageRoute(builder: (_) => const GameLoadingScreen()),
        );
      }
    });
  }

  @override
  void didChangeDependencies() {
    super.didChangeDependencies();
    precacheImage(const AssetImage('assets/loading_bg.png'), context);
    precacheImage(const AssetImage('assets/login_bg.png'), context);
    precacheImage(const AssetImage('assets/game_menu.png'), context);
  }

  @override
  void dispose() {
    _fadeController.dispose();
    super.dispose();
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      backgroundColor: Colors.black,
      body: Center(
        child: FadeTransition(
          opacity: _fadeAnimation,
          child: Image.asset(
            'assets/napo_studio.png',
            fit: BoxFit.contain, 
          ),
        ),
      ),
    );
  }
}

// ==========================================
// SCREEN 2: Loading Screen (Responsive Constraints)
// ==========================================
class GameLoadingScreen extends StatefulWidget {
  const GameLoadingScreen({super.key});

  @override
  State<GameLoadingScreen> createState() => _GameLoadingScreenState();
}

class _GameLoadingScreenState extends State<GameLoadingScreen> {
  double _progressValue = 0.0;
  late Timer _loadingTimer;

  @override
  void initState() {
    super.initState();
    _loadingTimer = Timer.periodic(const Duration(milliseconds: 30), (timer) {
      setState(() {
        if (_progressValue < 1.0) {
          _progressValue += 0.01;
        } else {
          _loadingTimer.cancel();
          Navigator.pushReplacement(
            context,
            MaterialPageRoute(builder: (_) => const AuthSelectionScreen()),
          );
        }
      });
    });
  }

  @override
  void dispose() {
    _loadingTimer.cancel();
    super.dispose();
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      backgroundColor: const Color(0xFF120C08),
      body: Stack(
        children: [
          Positioned.fill(
            child: Image.asset(
              'assets/loading_bg.png',
              fit: BoxFit.cover,
            ),
          ),
          Positioned.fill(
            child: Container(
              decoration: const BoxDecoration(
                gradient: LinearGradient(
                  begin: Alignment.topCenter,
                  end: Alignment.bottomCenter,
                  colors: [Colors.black38, Colors.black87],
                ),
              ),
            ),
          ),
          SafeArea(
            child: Align(
              alignment: Alignment.bottomCenter,
              child: Padding(
                padding: const EdgeInsets.symmetric(horizontal: 24.0, vertical: 40.0),
                child: Container(
                  constraints: const BoxConstraints(maxWidth: 600), 
                  child: Column(
                    mainAxisSize: MainAxisSize.min,
                    children: [
                      const Text(
                        'LOADING...',
                        style: TextStyle(
                          fontSize: 26,
                          fontWeight: FontWeight.bold,
                          color: Colors.white,
                          letterSpacing: 2.0,
                          shadows: [Shadow(color: Colors.black, blurRadius: 6)],
                        ),
                      ),
                      const SizedBox(height: 16),
                      Container(
                        height: 24,
                        padding: const EdgeInsets.all(4),
                        decoration: BoxDecoration(
                          color: const Color(0xFF1A120B),
                          borderRadius: BorderRadius.circular(12),
                          border: Border.all(color: const Color(0xFF3E2723), width: 2),
                        ),
                        child: ClipRRect(
                          borderRadius: BorderRadius.circular(8),
                          child: LinearProgressIndicator(
                            value: _progressValue,
                            backgroundColor: Colors.transparent,
                            valueColor: const AlwaysStoppedAnimation<Color>(Color(0xFF4CAF50)),
                          ),
                        ),
                      ),
                      const SizedBox(height: 16),
                      Text(
                        'Tip: Check every detail. The truth is always in the evidence.',
                        textAlign: TextAlign.center,
                        style: TextStyle(
                          fontSize: 15,
                          color: Colors.amber.shade100,
                          fontStyle: FontStyle.italic,
                          shadows: const [Shadow(color: Colors.black, blurRadius: 4)],
                        ),
                      ),
                    ],
                  ),
                ),
              ),
            ),
          ),
        ],
      ),
    );
  }
}

